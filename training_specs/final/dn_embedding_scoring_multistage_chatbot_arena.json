{
  "model": {
    "name": "dn-embedding-scoring-multistage-chatbot-arena",
    "start_state": null,
    "spec": {
      "model_type": "dn_embedding",
      "hidden_dims": [1024, 1024, 1024, 1024, 512, 512, 512, 256, 128],
      "dropout": 0.4,
      "use_skip_connections": true,
      "input_proj_dim": 64,
      "optimizer": {
        "optimizer_type": "muon",
        "learning_rate": 0.0005,
        "lr_decay_gamma": 0.99,
        "momentum": 0.95,
        "nesterov": true,
        "adamw_lr": 2e-5,
        "weight_decay": 0.01
      },
      "balance_model_samples": true,
      "embedding_model_name": "BAAI/bge-base-en-v1.5",
      "load_embedding_model_from": "gradient_boosting/gradient-boosting-scoring-chatbot-arena",
      "base_model": "gradient_boosting/gradient-boosting-scoring-only-llm-embedding-chatbot-arena",
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 200,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42,
    "dataset": "chatbot_arena"
  },
  "log": {
    "run_name": "dn-embedding-scoring-multistage-chatbot-arena",
    "print_every": 1
  },
  "epochs": 250,
  "batch_size": 512
}
