{
  "model": {
    "name": "gradient-boosting-scoring-finetunable-embedding-chatbot-arena",
    "start_state": null,
    "spec": {
      "model_type": "gradient_boosting",
      "max_depth": 5,
      "learning_rate": 0.1,
      "colsample_bytree": 0.8,
      "reg_alpha": 0.0,
      "reg_lambda": 1.0,
      "balance_model_samples": true,
      "input_features": ["prompt_features", "model_embedding", "prompt_embedding"],
      "embedding_model_name": "BAAI/bge-base-en-v1.5",
      "embedding_spec": {
        "embedding_type": "finetunable",
        "transformer_model_name": "BAAI/bge-base-en-v1.5",
        "finetuning_spec": {
          "method": "qlora",
          "bits": 4,
          "rank": 32,
          "alpha": 32,
          "dropout": 0.05,
          "target_modules": "auto"
        },
        "projection_dim": 128,
        "max_length": 256,
        "triplet_margin": 0.2,
        "regularization_weight": 0.01,
        "identity_positive_ratio": 1,
        "optimizer": {
          "optimizer_type": "adamw",
          "learning_rate": 1e-4,
          "lr_decay_gamma": 0.995,
          "weight_decay": 0.01
        }
      },
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 20,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42,
    "dataset": "chatbot_arena"
  },
  "log": {
    "run_name": "gradient-boosting-scoring-finetunable-embedding-chatbot-arena",
    "print_every": 1
  },
  "epochs": 100,
  "batch_size": 16
}
