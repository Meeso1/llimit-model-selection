{
  "model": {
    "name": "gradient-boosting-scoring-chatbot-arena",
    "start_state": null,
    "spec": {
      "model_type": "gradient_boosting",
      "max_depth": 5,
      "learning_rate": 0.1,
      "colsample_bytree": 0.8,
      "reg_alpha": 0.0,
      "reg_lambda": 1.0,
      "balance_model_samples": true,
      "input_features": ["prompt_features", "model_embedding", "prompt_embedding"],
      "embedding_model_name": "all-MiniLM-L6-v2",
      "embedding_spec": {
        "embedding_type": "attention",
        "encoder_model_name": "all-MiniLM-L6-v2",
        "h_emb": 256,
        "h_scalar": 64,
        "h_pair": 256,
        "d_out": 128,
        "pair_mlp_layers": 8,
        "num_attention_heads": 4,
        "dropout": 0.1,
        "temperature": 0.07,
        "pairs_per_model": 32,
        "models_per_batch": 16,
        "embeddings_per_model": 4,
        "optimizer": {
          "optimizer_type": "adamw",
          "learning_rate": 2e-4,
          "weight_decay": 0.01
        }
      },
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 100,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42,
    "dataset": "chatbot_arena"
  },
  "log": {
    "run_name": "gradient-boosting-scoring-chatbot-arena",
    "print_every": 1
  },
  "epochs": 100,
  "batch_size": 32
}
