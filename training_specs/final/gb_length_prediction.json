{
  "model": {
    "name": "gb-length-prediction",
    "start_state": null,
    "spec": {
      "model_type": "gb_length_prediction",
      "max_depth": 5,
      "learning_rate": 0.1,
      "colsample_bytree": 0.8,
      "colsample_bylevel": 0.8,
      "reg_alpha": 0.0,
      "reg_lambda": 1.0,
      "input_features": ["model_embedding", "prompt_features", "prompt_embedding", "model_id"],
      "embedding_model_name": "BAAI/bge-base-en-v1.5",
      "load_embedding_model_from": "gradient_boosting/gradient-boosting-scoring",
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 350
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42
  },
  "log": {
    "run_name": "gb-length-prediction",
    "print_every": 1
  },
  "epochs": 500,
  "batch_size": 32
}
