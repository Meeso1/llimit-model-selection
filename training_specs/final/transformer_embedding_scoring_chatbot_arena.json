{
  "model": {
    "name": "transformer-embedding-scoring-chatbot-arena",
    "start_state": null,
    "spec": {
      "model_type": "transformer_embedding",
      "transformer_model_name": "BAAI/bge-base-en-v1.5",
      "finetuning_spec": {
        "method": "lora",
        "rank": 16,
        "alpha": 32,
        "dropout": 0.05,
        "target_modules": "auto"
      },
      "hidden_dims": [1024, 512, 256, 128],
      "dropout": 0.2,
      "max_length": 256,
      "optimizer": {
        "optimizer_type": "muon",
        "learning_rate": 0.02,
        "lr_decay_gamma": 0.99,
        "momentum": 0.5,
        "nesterov": true,
        "adamw_lr": 1e-4,
        "weight_decay": 0.01
      },
      "balance_model_samples": true,
      "embedding_spec": {
        "embedding_type": "attention",
        "encoder_model_name": "all-MiniLM-L6-v2",
        "h_emb": 256,
        "h_scalar": 64,
        "h_pair": 256,
        "d_out": 128,
        "pair_mlp_layers": 8,
        "num_attention_heads": 4,
        "dropout": 0.1,
        "temperature": 0.07,
        "pairs_per_model": 32,
        "models_per_batch": 16,
        "embeddings_per_model": 4,
        "optimizer": {
          "optimizer_type": "adamw",
          "learning_rate": 2e-4,
          "weight_decay": 0.01
        }
      },
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 200,
      "proj_dim": 64,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42,
    "dataset": "chatbot_arena"
  },
  "log": {
    "run_name": "transformer-embedding-scoring-chatbot-arena",
    "print_every": 1
  },
  "epochs": 20,
  "batch_size": 32
}
