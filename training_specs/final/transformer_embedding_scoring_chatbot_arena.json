{
  "model": {
    "name": "transformer-embedding-scoring-chatbot-arena",
    "start_state": null,
    "spec": {
      "model_type": "transformer_embedding",
      "transformer_model_name": "BAAI/bge-base-en-v1.5",
      "finetuning_spec": {
        "method": "qlora",
        "rank": 32,
        "alpha": 32,
        "dropout": 0.05,
        "bits": 4,
        "target_modules": "auto"
      },
      "hidden_dims": [1024, 512, 256, 128],
      "dropout": 0.2,
      "max_length": 256,
      "optimizer": {
        "optimizer_type": "muon",
        "learning_rate": 0.005,
        "lr_decay_gamma": 0.99,
        "momentum": 0.99,
        "nesterov": true,
        "adamw_lr": 5e-5,
        "weight_decay": 0.001
      },
      "balance_model_samples": true,
      "load_embedding_model_from": "gradient_boosting/gradient-boosting-scoring-chatbot-arena",
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 200,
      "proj_dim": 64,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42,
    "dataset": "chatbot_arena"
  },
  "log": {
    "run_name": "transformer-embedding-scoring-chatbot-arena",
    "print_every": 1
  },
  "epochs": 120,
  "batch_size": 16
}
