{
  "model": {
    "name": "response-predictive-scoring-chatbot-arena",
    "start_state": null,
    "spec": {
      "model_type": "response_predictive",
      "response_repr_dim": 64,
      "encoder_hidden_dims": [1024, 1024, 512, 256, 128],
      "prediction_loss_weight": 0.2,
      "predictor_hidden_dims": [512, 512, 512, 512, 512, 512, 512, 512, 512],
      "scorer_hidden_dims": [512, 512, 512, 512, 512, 512, 512, 512, 512],
      "dropout": 0.4,
      "predictor_input_proj_dim": 128,
      "scorer_input_proj_dim": 128,
      "warmup_epochs": 0,
      "score_consistency_loss_weight": 0.5,
      "repr_dist_kl_loss_weight": 0.05,
      "optimizer": {
        "optimizer_type": "muon",
        "learning_rate": 0.005,
        "lr_decay_gamma": 0.99,
        "momentum": 0.9,
        "nesterov": true,
        "adamw_lr": 1e-4,
        "weight_decay": 0.001
      },
      "balance_model_samples": true,
      "embedding_model_name": "BAAI/bge-base-en-v1.5",
      "load_embedding_model_from": "gradient_boosting/gradient-boosting-scoring-chatbot-arena",
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 200,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "data": {
    "validation_split": 0.2,
    "seed": 42,
    "dataset": "chatbot_arena"
  },
  "log": {
    "run_name": "response-predictive-scoring-chatbot-arena",
    "print_every": 1
  },
  "epochs": 250,
  "batch_size": 1024
}
