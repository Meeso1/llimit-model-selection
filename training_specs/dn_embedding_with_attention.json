{
  "data": {
    "max_samples": null,
    "validation_split": 0.2,
    "seed": 42
  },
  "epochs": 250,
  "batch_size": 512,
  "model": {
    "name": "dn-embedding-loss-changes",
    "spec": {
      "model_type": "dn_embedding",
      "hidden_dims": [1024, 1024, 1024, 1024, 1024, 1024, 1024, 1024, 512, 512, 512, 512],
      "use_skip_connections": true,
      "input_proj_dim": 32,
      "optimizer": {
        "optimizer_type": "adamw",
        "learning_rate": 1e-5,
        "weight_decay": 0.99
      },
      "balance_model_samples": true,
      "embedding_model_name": "all-MiniLM-L6-v2",
      "embedding_spec": {
        "embedding_type": "attention",
        "encoder_model_name": "all-MiniLM-L6-v2",
        "h_emb": 256,
        "h_scalar": 64,
        "h_pair": 256,
        "d_out": 128,
        "pair_mlp_layers": 8,
        "num_attention_heads": 4,
        "dropout": 0.1,
        "temperature": 0.07,
        "pairs_per_model": 128,
        "models_per_batch": 8,
        "embeddings_per_model": 4,
        "optimizer": {
          "optimizer_type": "adamw",
          "learning_rate": 2e-5,
          "weight_decay": 0.995
        }
      },
      "min_model_comparisons": 1000,
      "embedding_model_epochs": 250,
      "ranking_loss_type": "bradley_terry"
    }
  },
  "log": {
    "run_name": "dn-embedding-loss-changes",
    "print_every": 1
  }
}

